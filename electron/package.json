{
  "name": "ddns-app",
  "version": "4.2.0",
  "description": "DDNS 动态域名解析服务客户端",
  "author": "DDNS Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild:win": "xcopy /E /I /Y ..\\src src && xcopy /E /I /Y ..\\public public",
    "build:win": "electron-packager . DDNS-Service --platform=win32 --arch=x64 --out=../dist --overwrite --icon=icon.ico --ignore=\"(node_modules/electron.*|node_modules/.*-builder.*|node_modules/ajv.*)\""
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-packager": "^17.1.2"
  }
}
