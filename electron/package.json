{
  "name": "ddns-app",
  "version": "4.2.0",
  "description": "DDNS 动态域名解析服务客户端",
  "author": "DDNS Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-packager . DDNS-Service --platform=win32 --arch=x64 --out=../dist --overwrite --icon=icon.ico"
  },
  "build": {
    "appId": "com.ddns.app",
    "productName": "DDNS Service",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "icon.png",
      "icon.ico",
      "../src/**/*",
      "../public/**/*",
      "../package.json"
    ],
    "win": {
      "target": "dir",
      "icon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2"
  }
}
